# ============================================
# Backend Environment Configuration
# ============================================

# AI Provider Configuration
# Options: "blazeapi" (primary) or "ollama" (fallback)
AI_PROVIDER=blazeapi

# BlazeAPI Configuration (Primary LLM Provider)
# Get your API key from: https://blazeai.boxu.dev
BLAZEAPI_API_KEY=your_blazeapi_key_here
BLAZEAPI_BASE_URL=https://blazeai.boxu.dev/api/
BLAZEAPI_MODEL=claude-opus-4-7

# Ollama Configuration (Fallback LLM Provider)
# Install Ollama from: https://ollama.com
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# MySQL Configuration (for direct schema extraction)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=True

# CORS Configuration (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================
# Optional: Advanced Configuration
# ============================================

# LLM Timeout (seconds)
LLM_TIMEOUT=300

# Max SQL Size (bytes)
MAX_SQL_SIZE=1048576

# Enable Request Logging
LOG_REQUESTS=True

# Database Connection Pool Size
DB_POOL_SIZE=10
